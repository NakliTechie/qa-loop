# qa-loop config — copy this file to .env and fill in your key:
#     cp .env.example .env
# Any OpenAI-compatible endpoint works: OpenRouter, TokenRouter, or a
# self-hosted vLLM / SGLang server. .env is gitignored — your key stays local.

# --- required ---------------------------------------------------------------
OPENAI_API_KEY=sk-replace-with-your-key

# Where to route each model (same gateway, or split coder/critic across two):
CODER_URL=https://openrouter.ai/api/v1
QA_URL=https://openrouter.ai/api/v1

# --- models -----------------------------------------------------------------
# Coder can be text-only. Critic MUST accept image input (it grades a screenshot).
CODER_MODEL=z-ai/glm-5.2
QA_MODEL=z-ai/glm-4.6v

# --- budgets / loop (optional; these are the defaults) ----------------------
CODER_MAXTOK=16000
QA_MAXTOK=2000
MAXROUNDS=4
